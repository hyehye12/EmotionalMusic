# =============================================
# Supabase (Settings > API)
# =============================================

# Project URL
REACT_APP_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# anon / public 키 (프론트엔드 Auth용)
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# service_role 키 (백엔드 DB 접근용 — 절대 프론트에 노출 금지)
REACT_APP_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Signing Key (Settings > Data API > JWT Settings)
# 없어도 동작하지만 있으면 토큰 검증이 더 빠름
REACT_APP_SUPABASE_JWT_SECRET=your-jwt-signing-key

# =============================================
# OpenAI (platform.openai.com > API keys)
# =============================================

OPENAI_API_KEY=sk-...

# =============================================
# 서버 주소
# 로컬 개발: http://localhost:5000
# 배포 후: Vercel 배포 시 빈 문자열("") 또는 동일 도메인 사용
# =============================================

REACT_APP_API_URL=http://localhost:5000
