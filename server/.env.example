# =============================================
# Supabase (Settings > API)
# =============================================

REACT_APP_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# service_role 키 (DB 관리자 권한)
REACT_APP_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Signing Key (Settings > Data API > JWT Settings)
REACT_APP_SUPABASE_JWT_SECRET=your-jwt-signing-key

# =============================================
# OpenAI (platform.openai.com > API keys)
# =============================================

OPENAI_API_KEY=sk-...

# =============================================
# 서버 포트 (기본값 5000)
# =============================================

PORT=5000
